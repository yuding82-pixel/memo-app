# Supabase 대시보드 > Settings > Database > Connection string 에서 복사
# Session mode (권장, IPv4 지원)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# 연결 테스트용 (선택)
SUPABASE_PROJECT_REF="your-project-ref"
SUPABASE_DB_PASSWORD="your-db-password"

# Supabase 클라이언트용 (선택)
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Vercel 배포 시 API 서버 주소 (Render 등 백엔드 URL)
# Vercel 대시보드 > Settings > Environment Variables 에 설정
VITE_API_URL="https://your-api.onrender.com"
