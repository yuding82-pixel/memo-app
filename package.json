{
  "name": "-",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run server\" \"npm run client\"",
    "start": "npm run dev",
    "postinstall": "node scripts/prisma-generate-safe.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:migrate-data": "node scripts/migrate-sqlite-to-supabase.js",
    "db:setup-supabase": "node scripts/setup-supabase.js",
    "db:test-connection": "node scripts/test-supabase-connection.js",
    "server": "node scripts/ensure-database-url.js && prisma generate && prisma migrate deploy && node server/index.js",
    "client": "node ./node_modules/vite/bin/vite.js --open",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prisma": "^6.19.3",
    "vite": "^8.0.12"
  }
}
